{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Portfolio Dev Server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "portfolio", "dev"],
      "cwd": "${workspaceFolder}",
      "env": {
        "PORT": "3000",
        "BASE_PATH": "/"
      },
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}